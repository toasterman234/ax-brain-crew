# ── LLM endpoint (pick one path) ──────────────────────────────────────
# Path A: Standard OpenAI-compatible endpoint (recommended for new users)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
# Path B: CommandCode proxy (Ben's existing setup — ignored if OPENAI_* set)
# PROXY_BASE_URL=http://127.0.0.1:8787/v1
# PROXY_API_KEY=your-commandcode-proxy-key

# ── Vault (optional) ──────────────────────────────────────────────────
# Leave empty to run without a vault. Vault tools will return "vault not configured".
# Set to a path to enable vault read/write/search tools.
OBSIDIAN_VAULT_PATH=./vault
EXTERNAL_VAULT_PATH=
# ── Demo mode (optional) ──────────────────────────────────────────────
# Set to true for a clean demo experience: uses demo agents, stubs
# personal integrations (Slack, Langfuse, agentmemory, LifeOS).
# CREW_DEMO_MODE=false

# ── Model IDs (passed to your LLM endpoint) ───────────────────────────
FAST_MODEL=deepseek/deepseek-v4-pro
SMART_MODEL=deepseek/deepseek-v4-pro
DATABASE_PATH=./data/crew.sqlite
LOG_LEVEL=info
MAX_HANDOFF_DEPTH=3
DRY_RUN=true
ROUTING_CONFIDENCE_THRESHOLD=0.80
ROUTING_CLARIFY_THRESHOLD=0.55

# Vault tool exclusions – comma-separated directories agents cannot read/write/list/search
VAULT_EXCLUDED_DIRS=_taskboard,_trash

# Scout – system & GitHub explorer (optional)
# Comma-separated list of paths Scout can explore
SCOUT_ALLOWED_PATHS=/Users/yourname,/Volumes/External
# GitHub personal access token (classic) with repo scope
GITHUB_TOKEN=
# GitHub username
GITHUB_USER=

# Memory tool (memory.recall / memory.save) – agentmemory REST API (optional)
# Base URL of the local agentmemory REST server. Default works out of the box.
AGENTMEMORY_BASE_URL=http://127.0.0.1:3111/agentmemory
# Bearer secret; without it recall degrades to empty results.
AGENTMEMORY_SECRET=

# Life OS tool (life.query) – semantic-search API (optional, Seeker-only)
# Reaches real financial/health data; read-only. Default is the local API server.
LIFEOS_BASE_URL=http://127.0.0.1:8447

# Web tool (web.search / research.*) – Serper (Google Search) API (optional, Seeker-only)
# Reuses Ben's existing Serper key. Resolved in priority order:
#   1. SERPER_API_KEY here (or in the shell env)
#   2. ~/.life/secrets/serper.env  (format: SERPER_API_KEY=... , same key Life OS uses)
# When no key is found, web.search returns a "not configured" string and web.fetch
# (keyless) still works. Required to run the async `crew worker` research loop for real.
SERPER_API_KEY=

# Background research worker step budget (crew worker only, not the live chat cap).
# The live chat turn stays at CREW_MAX_STEPS=4; the worker sets its own generous
# budget for search -> fetch -> reason. Default 12.
CREW_WORKER_MAX_STEPS=12
