{
  "name": "ax-brain-crew",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first TypeScript agent crew powered by AxLLM, routing natural-language requests to vault-aware specialists.",
  "scripts": {
    "crew": "npx tsx --env-file=.env src/cli/main.ts",
    "bridge": "npx tsx --env-file=.env src/bridge/slack.ts",
    "docs": "npx tsx --env-file=.env scripts/generate-docs.ts",
    "model-config": "npx tsx scripts/generate-agent-model-config.ts",
    "sweep-stranded": "npx tsx --env-file=.env scripts/sweep-stranded-runs.ts",
    "sync:watchlist": "python3 scripts/sync-watchlist-to-mira.py",
    "watch:watchlist": "bash scripts/watch-watchlist.sh",
    "live:watchlist": "python3 scripts/live-watchlist.py",
    "pull:holdings": "python3 scripts/pull-holdings-to-watchlist.py",
    "check:enforcement": "tsx scripts/check-vault-enforcement.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@ax-llm/ax": "23.0.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@slack/bolt": "^5.0.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "langfuse": "^3.38.20",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
