{
  "name": "ax-visual-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:clean && next dev --turbopack -p 3020",
    "dev:clean": "lsof -ti :3020 | xargs kill -9 2>/dev/null; echo 'Port 3020 cleared'",
    "build": "next build",
    "start": "next start -p 3020",
    "smoke": "curl -sf -o /dev/null -w '%{http_code}' http://127.0.0.1:3020",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.14",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.12.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^3.0.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0"
  }
}
